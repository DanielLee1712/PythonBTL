# ── LLM Provider ──
GROQ_API_KEY=your_groq_api_key_here

# ── Neo4j Knowledge Base Graph ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Product Database (Postgres) ──
PRODUCT_DB_HOST=localhost
PRODUCT_DB_PORT=5434
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=shop_user
PRODUCT_DB_PASS=shop_password

# ── Product Service API ──
PRODUCT_SERVICE_PRODUCTS_URL=http://localhost:8001/api/v1/products/

# ── Ollama Fallback (Local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434
