# Copy to ".env" in this folder (same level as docker-compose.yml).
# Docker Compose loads it for ${VNPAY_...} → payment-service.

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Browser returns here after paying; must hit API gateway so the backend can verify signature and mark paid.
VNPAY_RETURN_URL=http://localhost:8080/api/payment/api/v1/payments/vnpay/return/

# After success/failure, user is redirected to this site (usually your Vite dev server).
VNPAY_FRONTEND_URL=http://localhost:5173/

VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# IPN: VNPAY server calls this URL (localhost only works if VNPAY can reach it, e.g. ngrok in real tests).
VNPAY_IPN_URL=http://localhost:8080/api/payment/api/v1/payments/vnpay/ipn/
